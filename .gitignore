# Doom-generated
.local/
.cache/

# Per-daemon persp state (machine-local). Trailing `*` catches persp-mode's
# rotated/numbered variants too (e.g. .persp-state-soc.el1).
.persp-state-*.el*

# EDA daemon registry (machine-local — contains absolute home paths)
eda-registry.el

# EDA per-machine overrides (secrets/paths/profile/sync emails; E11)
.eda-local.el

# Per-worktree org task file (this dir is the `doom' worktree). Machine-local;
# may hold personal/client task content that must NOT enter the config repo.
project.org

# Compiled elc
*.elc

# Backup files
*~
\#*\#
.\#*

# OS noise
.DS_Store

# Claude Code local settings / session data
.claude/
