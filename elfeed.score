;;; elfeed.score — Unified scoring for three-tier feed structure
;;;
;;; PHILOSOPHY:
;;;   Tier 1 (semiconductor work domain)  →  STRONG BOOSTS
;;;   Tier 2 (secondary active interests) →  MILD or NO adjustment
;;;   Tier 3 (parked :ignore: sections)   →  not imported, so no scoring
;;;
;;; Higher = top of list. Negative = bottom. Default score = 0.
;;; Reload after editing: press "=" inside *elfeed-search* buffer.

(("title"
  ;; ============================================================
  ;; TIER 1 BOOSTS — Work-domain signals
  ;; ============================================================

  ;; Open Silicon / EDA (highest priority)
  ("OpenROAD"              150 S)
  ("OpenLane"              120 S)
  ("Tiny Tapeout"          100 S)
  ("SkyWater"               90 S)
  ("RISC-V"                 90 s)
  ("chiplet"                80 s)
  ("tapeout"                70 s)

  ;; India Semiconductor Mission & ecosystem
  ("ISM 2.0"               150 S)
  ("Semicon India"         130 S)
  ("India Semiconductor"   120 s)
  ("Tata Electronics"      100 s)
  ("Tata Semiconductor"    100 s)
  ("Micron Sanand"         100 s)
  ("MeitY"                  80 s)
  ("Mindgrove"              70 s)
  ("InCore"                 70 s)
  ("SignalChip"             70 s)
  ("Saankhya Labs"          70 s)
  ("FermionIC"              70 s)

  ;; Core semi / VLSI
  ("VLSI"                   70 s)
  ("EDA"                    50 s)
  ("fabless"                60 s)
  ("foundry"                40 s)
  ("TSMC"                   50 s)
  ("ASML"                   50 s)
  ("lithography"            40 s)

  ;; AI-in-semi high-signal names
  ("SemiAnalysis"          100 S)
  ("Dylan Patel"           100 s)
  ("Tenstorrent"            80 s)
  ("Cerebras"               80 s)
  ("Groq"                   70 s)
  ("NVCell"                 80 s)
  ("chip design"            50 s)
  ("AI accelerator"         60 s)
  ("NPU"                    40 s)

  ;; Funding signals
  ("Series A"               50 s)
  ("Series B"               50 s)
  ("Series C"               40 s)
  ("Series D"               40 s)
  ("raised"                 40 s)
  ("seed funding"           40 s)
  ("pre-Series"             40 s)
  ("acqui"                  30 s)  ; acquired/acquisition

  ;; PCB / embedded signals
  ("PCB"                    30 s)
  ("SMT"                    25 s)
  ("FPGA"                   40 s)
  ("embedded linux"         30 s)
  ("microcontroller"        25 s)

  ;; ============================================================
  ;; TIER 1 DEMOTES — Niche supplements within work domain
  ;; (still shown, but ranked lower)
  ;; ============================================================
  ("photonics"             -30 s)
  ("compound semi"         -30 S)
  ("GaN"                   -20 s)
  ("SiC"                   -20 s)
  ("RF"                    -25 s)
  ("analog"                -15 s)
  ("quantum"               -40 s)
  ("MEMS"                  -30 s)
  ("LED"                   -35 s)
  ("OLED"                  -25 s)

  ;; Noisy general-AI topics not chip-related
  ("ChatGPT"               -40 s)
  ("prompt engineering"    -30 s)
  ("LLM"                   -10 s)   ; mild — still relevant occasionally

  ;; ============================================================
  ;; TIER 2 MILD ADJUSTMENTS — Secondary interests
  ;; (kept readable but not crowding work content)
  ;; ============================================================

  ;; Signals I want to see from general news/tech
  ("Anthropic"              20 S)
  ("privacy"                15 s)
  ("open source"            15 s)

  ;; Cruft to push down even from trusted sources
  ("royal"                 -30 s)
  ("celebrity"             -30 s)
  ("sports"                -20 s)
  ("cricket score"         -25 s))

 ("content"
  ;; Body-text matches — weaker weights by design
  ("OpenROAD"                40 s)
  ("ISM 2.0"                 50 s)
  ("India Semiconductor Mission" 40 s)
  ("Indian startup"          40 s)
  ("fab"                     20 s)
  ("tapeout"                 30 s)
  ("RTL to GDS"              50 s)
  ("chip design"             20 s)
  ("semiconductor fab"       30 s)

  ;; Demotes in body
  ("photonics"              -20 s)
  ("quantum computing"      -25 s)
  ("automotive grade"       -15 s))

 ("tag"
  ;; ============================================================
  ;; TAG-BASED BOOSTS (Tier 1)
  ;; ============================================================
  (("opensilicon" "openroad")         100)
  (("opensilicon" "openlane")          90)
  (("opensilicon")                     70)
  (("ai-semi" "analysis")              80)
  (("ai-semi")                         60)
  (("india" "startup")                 90)
  (("india" "govt")                    80)
  (("india" "deeptech")                80)
  (("india")                           60)
  (("semi" "deepdive")                 70)
  (("semi")                            50)
  (("vlsi")                            70)
  (("vlsi" "eda")                      70)
  (("embedded" "linux")                50)
  (("embedded")                        40)
  (("pcb" "mfg")                       40)
  (("pcb")                             30)
  (("hn" "opensilicon")                60)
  (("funding")                         50)
  (("startup" "funding")               60)
  (("fabs" "equipment")                40)
  (("fabs")                            30)

  ;; ============================================================
  ;; TAG-BASED DEMOTES (Tier 1 niches + Tier 2 keep-but-lower)
  ;; ============================================================
  (("specialty")                      -40)
  (("specialty" "photonics")          -50)
  (("specialty" "compound")           -40)
  (("automotive" "europe")            -30)
  (("research" "arxiv")               -20)
  (("paywalled")                      -30)
  (("finance" "wsj")                  -15)
  (("finance" "ft")                   -15)

  ;; Tier 2 secondary interests — keep but rank below work
  (("news")                           -10)
  (("magazine")                       -10)
  (("technology")                       0)   ; neutral — don't push down
  (("youtube-misc")                   -30))  ; if you ever re-enable it

 ("feed"
  ;; ============================================================
  ;; FEED-LEVEL BOOSTS — Trusted high-signal sources
  ;; ============================================================
  ("semiengineering.com"      40 s t)
  ("semianalysis.substack"    50 s t)
  ("semiwiki.com"             30 s t)
  ("theopenroadproject"       60 s t)
  ("tinytapeout.com"          50 s t)
  ("zerotoasiccourse"         40 s t)
  ("ism.gov.in"               60 s t)
  ("pib.gov.in"               30 s t)
  ("inc42.com"                30 s t)
  ("entrackr.com"             30 s t)
  ("yourstory.com"            20 s t)
  ("electronicsforu.com"      25 s t)
  ("electronicsb2b"           20 s t)
  ("eetimes.com"              25 s t)
  ("edn.com"                  20 s t)
  ("design-reuse.com"         30 s t)
  ("github.com"               30 s t)   ; OpenROAD/OpenLane release atoms

  ;; Tier 2 mustreads
  ("stratechery.com"          20 s t)

  ;; ============================================================
  ;; FEED-LEVEL DEMOTES — Firehose or off-topic sources
  ;; ============================================================
  ("arxiv.org"               -30 s t)
  ("hackaday.com"            -10 s t)
  ("omdia.com"               -20 s t)
  ("photonics.com"           -40 s t)
  ("compoundsemiconductor"   -40 s t)
  ("powerelectronicsnews"    -30 s t)
  ("eenewseurope"            -20 s t)

  ;; Tier 2 — general news, push below work
  ("techcrunch.com"          -15 s t)   ; useful but firehose
  ("theverge.com"            -20 s t)
  ("arstechnica.com"         -10 s t))

 ;; ============================================================
 ;; AUTO-MARK-READ THRESHOLD
 ;; Entries scoring below this get marked as read automatically.
 ;; ============================================================
 (mark -100))
